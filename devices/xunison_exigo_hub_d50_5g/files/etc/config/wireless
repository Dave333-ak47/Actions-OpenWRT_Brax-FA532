config wifi-device 'radio0'
        option type 'mac80211'
        option hwmode '11a'
        option path 'pci0000:00/0000:00:00.0'
        option htmode 'HE80'
        option channel 'auto'

config wifi-iface
        option device 'radio0'
        option mode 'ap'
        option ssid 'D50-5G'
        option encryption 'psk2'
        option key 'password123'
